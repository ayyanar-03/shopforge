# ── Database (Supabase) ────────────────────────────────────────────────────
# Get from: Supabase → Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
DB_SSL=true

# ── Redis (Upstash) ────────────────────────────────────────────────────────
# Get from: Upstash → your database → REST URL / Redis URL
REDIS_HOST=your-redis.upstash.io
REDIS_PORT=6379
REDIS_PASSWORD=your-upstash-password

# ── Auth ───────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-string-min-32-chars
INTERNAL_TOKEN=change-this-to-another-long-random-string

# ── Email (Resend) ─────────────────────────────────────────────────────────
# Get from: resend.com → API Keys
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=re_your_api_key_here
SMTP_FROM=ShopForge <orders@yourdomain.com>

# ── Frontend ───────────────────────────────────────────────────────────────
# The public URL of your gateway (Render service URL)
VITE_API_BASE_URL=https://shopforge-gateway.onrender.com
VITE_CURRENCY_RATE=83.5

# ── Payments (optional) ────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ── Observability (optional) ───────────────────────────────────────────────
GRAFANA_PASSWORD=shopforge
