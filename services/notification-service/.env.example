# Notification-service (NestJS :3003)
NODE_ENV=development
PORT=3003

# Redis (BullMQ queue connection)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# SMTP (e.g. Mailhog for dev: smtp://localhost:1025)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_FROM=noreply@shopforge.com
SMTP_PASS=

# Observability
LOG_LEVEL=info
OTEL_SERVICE_NAME=notification-service
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
