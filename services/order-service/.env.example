# Order-service (NestJS :3002)
NODE_ENV=development
PORT=3002

# MySQL
DB_HOST=127.0.0.1
DB_PORT=3307
DB_USER=shopforge_user
DB_PASSWORD=shopforge_pass
DB_NAME=shopforge

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Auth
JWT_SECRET=change-me-in-production

# Internal token for catalog-service calls
INTERNAL_TOKEN=internal-secret

# Catalog service URL (for internal API calls)
CATALOG_SERVICE_URL=http://localhost:3001

# CORS
CORS_ORIGIN=http://localhost:5173

# Payment gateways
STRIPE_SECRET_KEY=sk_test_...
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=...

# Observability
LOG_LEVEL=info
OTEL_SERVICE_NAME=order-service
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
