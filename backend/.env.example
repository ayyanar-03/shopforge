# Catalog-service (NestJS :3001)
NODE_ENV=development
PORT=3001

# MySQL
DB_HOST=127.0.0.1
DB_PORT=3307
DB_USER=shopforge_user
DB_PASSWORD=shopforge_pass
DB_NAME=shopforge

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Auth
JWT_SECRET=change-me-in-production

# Internal service token (must match ORDER_SERVICE token)
INTERNAL_TOKEN=internal-secret

# Other services
ORDER_SERVICE_URL=http://localhost:3002

# Observability
LOG_LEVEL=info
OTEL_SERVICE_NAME=catalog-service
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
